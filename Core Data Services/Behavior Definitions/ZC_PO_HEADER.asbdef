projection;
strict ( 2 );
use draft;

define behavior for ZC_PO_HEADER alias POHeader
{
  use create;
  use update;
  use delete;

  use action createPurchaseOrder;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _Item { create; with draft; }
}

define behavior for ZC_PO_ITEM alias POItem
{
  use update;
  use delete;

  use association _Header { with draft; }
}
